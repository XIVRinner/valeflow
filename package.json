{
  "name": "flowscript",
  "version": "0.1.0",
  "description": "A TypeScript-first dialogue scripting engine and DSL for branching narratives, featuring a step-based runtime, scoped variables, and extensible hooks.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/XIVRinner/flowscript.git"
  },
  "homepage": "https://xivrunner.github.io/flowscript/",
  "bugs": {
    "url": "https://github.com/XIVRinner/flowscript/issues"
  },
  "keywords": [
    "dialogue",
    "scripting",
    "DSL",
    "narrative",
    "game",
    "engine",
    "visual-novel",
    "typescript"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
